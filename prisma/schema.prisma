generator pyclient {
  provider             = "prisma-client-py"
  recursive_type_depth = "5"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")  
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  phoneNo       String
  role          Role           @default(STUDENT)
  dateOfBirth   DateTime
  city          String
  country       String
  pincode       String
  state         String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
  school        School[]
  student       Student?
  teacher       Teacher?
}

model Student {
  id              String        @id @default(cuid())
  userId          String        @unique
  rollNo          String        @unique
  parentName      String
  parentEmail     String
  dateOfAdmission DateTime      @default(now())
  classId         String
  schoolId        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  schoolClass     SchoolClass   @relation(fields: [classId], references: [id], onDelete: Cascade)
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentExams    StudentExam[]

  @@index([classId])
  @@index([userId])
}

model Teacher {
  id            String         @id @default(cuid())
  userId        String         @unique
  qualification String         @default("[]")
  experience    Int
  department    String
  subjects      String         @default("[]")
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  exams         Exam[]
  principal     Principal?
  school        School?        @relation(fields: [schoolId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  teaches       TeacherClass[]

  @@index([userId])
}

model TeacherClass {
  id          String      @id @default(cuid())
  teacherId   String
  classId     String
  subject     Subject
  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher     Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
  @@index([teacherId])
  @@index([classId])
}

model SchoolClass {
  id        String         @id @default(cuid())
  name      String         // display name, e.g. "12th - A" (can be auto-generated)
  year      String         // grade/year level, e.g. "12th", "10th", "1st"
  section   String         @default("A") // batch/section, e.g. "A", "B", "C"
  schoolId  String
  teacherId String?        // class teacher / homeroom teacher
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  school    School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students  Student[]
  teachers  TeacherClass[]

  @@unique([schoolId, year, section]) // no duplicate "12th A" in same school
  @@index([schoolId])
  @@index([teacherId])
}

model Principal {
  id         String   @id @default(cuid())
  experience Int
  schoolId   String?
  teacherId  String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  school     School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([teacherId])
}

model School {
  id         String        @id @default(cuid())
  name       String
  createdBy  String
  address    String
  city       String
  state      String
  country    String
  pincode    String
  schoolCode String        @unique
  type       SchoolType    @default(PUBLIC)
  email      String?
  website    String?      
  phoneNo    String?  
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  principals Principal[]
  user       User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  classes    SchoolClass[]
  Student    Student[]
  teachers   Teacher[]
}

model Exam {
  id           String        @id @default(cuid())
  name         String
  description  String
  scheduledAt  DateTime
  duration     Int
  maxMarks     Int
  instructions String?
  isPublished  Boolean       @default(false)
  subject      Subject?
  type         ExamType
  teacherId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  questions    Question[]
  studentExams StudentExam[]

  @@index([teacherId])
}

model Question {
  id             String              @id @default(cuid())
  questionNumber Int
  text           String
  section        String?
  marks          Int
  imageUrl       String?
  wordLimit      Int?
  explanation    String?
  questionType   QuestionType        @default(MULTIPLE_CHOICE)
  examId         String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  exam           Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  options        QuestionOption[]
  answers        StudentExamAnswer[]

  @@unique([examId, questionNumber, section])
  @@index([examId])
}

model QuestionOption {
  id           String           @id @default(cuid())
  optionNumber Int              @default(0)
  questionId   String
  text         String
  isCorrect    Boolean          @default(false)
  imageUrl     String?
  question     Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedBy   SelectedOption[]

  @@unique([questionId, optionNumber])
  @@index([questionId])
}

model StudentExam {
  id            String              @id @default(cuid())
  studentId     String
  examId        String
  marksObtained Int                 @default(0)
  startedAt     DateTime            @default(now())
  submittedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  status        StudentExamStatus   @default(IN_PROGRESS)
  exam          Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers       StudentExamAnswer[]

  @@unique([studentId, examId])
  @@index([studentId])
  @@index([examId])
}

model StudentExamAnswer {
  id              String           @id @default(cuid())
  studentExamId   String
  questionId      String
  questionType    QuestionType
  textAnswer      String?
  marksAwarded    Int?             @default(0)
  feedback        String?
  isCorrect       Correctness?
  gradingStatus   GradingStatus    @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  question        Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentExam     StudentExam      @relation(fields: [studentExamId], references: [id], onDelete: Cascade)
  selectedOptions SelectedOption[]

  @@unique([studentExamId, questionId])
  @@index([studentExamId])
  @@index([questionId])
}

model SelectedOption {
  id                  String            @id @default(cuid())
  studentExamAnswerId String
  optionId            String
  studentExamAnswer   StudentExamAnswer @relation(fields: [studentExamAnswerId], references: [id], onDelete: Cascade)
  option              QuestionOption    @relation(fields: [optionId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  @@unique([studentExamAnswerId, optionId])
  @@index([studentExamAnswerId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Enums ─────────────────────────────────────────────────────//

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PRINCIPAL
}

enum Subject {
  MATHS
  SCIENCE
  HISTORY
  LITERATURE
  ART
  MUSIC
  PHYSICAL_EDUCATION
}

enum ExamType {
  MIDTERM
  FINAL
  QUIZ
  ASSIGNMENT
  MOCK
}

enum Qualification {
  BACHELORS
  MASTERS
  PHD
  OTHER
  BACHELORS_WITH_HONORS
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
}

enum SchoolType {
  PUBLIC
  PRIVATE
  CHARTER
  INTERNATIONAL
}

enum StudentExamStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  EXPIRED
  NOT_ATTEMPTED
}

enum GradingStatus {
  PENDING
  AUTO_GRADED
  MANUALLY_GRADED
}

enum Correctness {
  FULLY_CORRECT
  PARTIALLY_CORRECT
  INCORRECT
}

