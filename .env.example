# ============================================================
# ExamArena — Environment Variables Example
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ============================================================

# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection URL (e.g. Neon, Supabase, local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require"

# ─── Authentication (Clerk) ─────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_CLERK_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_YOUR_CLERK_SECRET_KEY"

# ─── JWT (Backend Auth) ─────────────────────────────────────
# Use a strong random secret: `openssl rand -hex 32`
SECRET_KEY="REPLACE_WITH_STRONG_RANDOM_SECRET"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Environment ────────────────────────────────────────────
ENVIRONMENT="development"
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS="http://localhost:3000"

# ─── API URL (Frontend) ─────────────────────────────────────
# Do NOT include /api at the end — backend routes are /api/v1/...
NEXT_PUBLIC_API_URL="http://localhost:8000"

# ─── Redis ──────────────────────────────────────────────────
# Full Redis URL including credentials and port
REDIS_URL="redis://default:PASSWORD@HOST:PORT"
REDIS_CACHE_EXPIRE_SECONDS=3600
REDIS_RATE_LIMIT_EXPIRE_SECONDS=60
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_TIME_WINDOW_SECONDS=60
REDIS_DATABASE_NAME="your-redis-db-name"

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY="sk-YOUR_OPENAI_API_KEY"

# ─── Cloudinary (Image Uploads) ─────────────────────────────
CLOUDINARY_APIKEY="YOUR_CLOUDINARY_API_KEY"
CLOUDINARY_APISECRET="YOUR_CLOUDINARY_API_SECRET"
CLOUDINARY_CLOUDNAME="YOUR_CLOUDINARY_CLOUD_NAME"

# ─── Sentry (Error Monitoring) ──────────────────────────────
SENTRY_DSN="https://YOUR_KEY@sentry.io/YOUR_PROJECT_ID"
SENTRY_AUTH_TOKEN="sntrys_YOUR_SENTRY_AUTH_TOKEN"
